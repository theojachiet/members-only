<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Home</title>
</head>

<body>
    <p>
        <%= currentUser ? currentUser.username : 'Guest' %>, you can write a message here
    </p>
    <p>Admin: <%= currentUser.is_admin ? "Yes" : "No" %>
    </p>
    <form action="/createMessage" method="POST">
        <label for="text">Your message:</label>
        <textarea name="text" id="text" rows="10" cols="20"></textarea>
        <button type="submit">Submit message</button>
    </form>
    <a href="/messages">Back to messages</a>
    <form action="/logout" method="POST">
        <button type="submit">Logout</button>
    </form>

</body>

</html>